# Doxyfile for discriminator_estimates module
# Generated: 2026-03-28
# Минимальный рабочий конфиг — запуск: doxygen Doxyfile

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "Discriminator Estimates (КППО/ТЗК)"
PROJECT_BRIEF          = "Дискриминаторные оценки координат цели по отсчётам ДН антенны"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = .
OUTPUT_LANGUAGE        = Russian

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = ../../include ../../src pages
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = NO
INPUT_ENCODING         = UTF-8

#---------------------------------------------------------------------------
# Build / Extract
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
EXTRACT_LOCAL_CLASSES   = YES

#---------------------------------------------------------------------------
# C-specific
#---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_FOR_C  = YES

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

#---------------------------------------------------------------------------
# Documentation style
#---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
TAB_SIZE               = 2
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
FULL_PATH_NAMES        = NO

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html

# MathJax для формул (без установки LaTeX)
USE_MATHJAX            = YES
MATHJAX_VERSION        = MathJax_3

# Картинки (графики из plots/)
# ВНИМАНИЕ: Doxygen НЕ обходит подкаталоги IMAGE_PATH рекурсивно — каждый
# подкаталог должен быть указан явно. Иначе картинки из plots/1_animation/,
# plots/5_recommendations/ и т.п. не будут найдены.
IMAGE_PATH             = ../plots \
                         ../plots/1_animation \
                         ../plots/2_no_noise \
                         ../plots/3_noise \
                         ../plots/4_3d \
                         ../plots/5_recommendations

#---------------------------------------------------------------------------
# LaTeX output
#---------------------------------------------------------------------------
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = pdflatex
MAKEINDEX_CMD_NAME     = makeindex
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
EXTRA_PACKAGES         =
LATEX_HEADER           = header.tex
LATEX_FOOTER           = footer.tex
LATEX_EXTRA_STYLESHEET =
LATEX_EXTRA_FILES      =
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = NO
LATEX_HIDE_INDICES     = NO
LATEX_BIB_STYLE        = plain

#---------------------------------------------------------------------------
# Dot / Graphviz (disabled)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO

#---------------------------------------------------------------------------
# Miscellaneous
#---------------------------------------------------------------------------
QUIET                  = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO
